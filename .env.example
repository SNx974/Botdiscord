# Local dev (apps run on the host, talking to docker-compose.dev.yml): use localhost.
# Dokploy / docker-compose.yml: DATABASE_URL and REDIS_URL point at separate
# Dokploy "Database" resources (Postgres, Redis) you create in the project —
# copy their internal connection string from the Dokploy UI.

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/matchmaking_akd?schema=public"
# Dokploy: DATABASE_URL="postgresql://<user>:<password>@<dokploy-postgres-internal-host>:5432/<db>"

# --- Redis (pub/sub + BullMQ queue) ---
REDIS_URL="redis://localhost:6379"
# Dokploy: REDIS_URL="redis://<user>:<password>@<dokploy-redis-internal-host>:6379"

# --- Discord Bot ---
DISCORD_BOT_TOKEN="changeme"
DISCORD_CLIENT_ID="changeme"
DISCORD_CLIENT_SECRET="changeme"
DISCORD_GUILD_ID="changeme"
DISCORD_MATCH_CATEGORY_ID="changeme"
DISCORD_ADMIN_ROLE_ID="changeme"

# Shared secret used by apps/web -> apps/bot and apps/web -> apps/realtime internal HTTP APIs
INTERNAL_API_SECRET="changeme-internal-secret"

# Internal listen port for apps/bot and apps/realtime (each container is
# isolated, so both can safely use the same number). Falls back to 4001/4002
# individually if not set.
API_PORT=4000

# Used by apps/web to reach the bot's internal API and the realtime server's
# internal broadcast endpoint. Dokploy (docker-compose.yml): these resolve
# automatically to http://bot:${API_PORT} / http://realtime:${API_PORT}.
BOT_INTERNAL_URL="http://localhost:4001"
REALTIME_URL="http://localhost:4002"

# The browser connects to this one directly, so it must be a PUBLIC URL with
# a domain Dokploy has exposed for the realtime service (not the internal
# "realtime" hostname). It's also a Next.js build arg (see apps/web/Dockerfile)
# since NEXT_PUBLIC_* vars are inlined into the client bundle at build time.
NEXT_PUBLIC_REALTIME_URL="http://localhost:4002"

# --- NextAuth (Discord OAuth login on the web dashboard) ---
# NEXTAUTH_URL must be the public URL of the web app (used for OAuth callback).
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="changeme-nextauth-secret"

# --- OCR ---
# "gpt4o": uses OPENAI_API_KEY (GPT-4o vision reads the score directly off the screenshot).
# "gemini": uses GEMINI_API_KEY (Gemini 2.0 Flash, same approach — get a free key at https://aistudio.google.com/apikey).
# "ollama": uses your own self-hosted Ollama instance (OLLAMA_BASE_URL/OLLAMA_MODEL) — no
#   external quota at all, but slower and less accurate than a hosted vision model.
# "vision": uses Google Cloud Vision (GOOGLE_APPLICATION_CREDENTIALS) + regex score parsing.
OCR_PROVIDER="vision"
OPENAI_API_KEY="changeme"
GEMINI_API_KEY="changeme"
OLLAMA_BASE_URL="http://152.228.128.146:11434"
OLLAMA_MODEL="moondream"
GOOGLE_APPLICATION_CREDENTIALS="./gcp-vision-key.json"

# --- Storage (screenshots, S3-compatible) ---
# docker-compose.yml bundles a MinIO service (internal hostname "minio") and
# auto-creates/publishes the bucket on first deploy (see the `minio-init` service).
# Use Cloudflare R2 / AWS S3 instead by pointing these at your provider.
S3_ENDPOINT="http://minio:9000"
S3_BUCKET="matchmaking-screenshots"
S3_ACCESS_KEY="changeme"
S3_SECRET_KEY="changeme"
S3_REGION="us-east-1"
# Publicly reachable base URL for uploaded screenshots (Discord/the browser
# can't resolve S3_ENDPOINT if it's an internal-network hostname like MinIO).
# For the bundled MinIO: http://<your-public-domain>:9000/<S3_BUCKET>
S3_PUBLIC_URL="changeme"
